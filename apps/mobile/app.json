{
  "expo": {
    "name": "HairConnekt",
    "slug": "hairconnekt",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "de.hairconnekt.app",
      "googleServicesFile": "./src/GoogleService-Info.plist",
      "infoPlist": {
        "NSCameraUsageDescription": "HairConnekt needs access to your camera to allow you to take photos for your profile and portfolio.",
        "NSPhotoLibraryUsageDescription": "HairConnekt needs access to your photo library to allow you to upload photos to your profile and portfolio.",
        "NSLocationWhenInUseUsageDescription": "HairConnekt needs your location to show braiders and services near you."
      }
    },
    "android": {
      "package": "de.hairconnekt.app",
      "googleServicesFile": "./src/google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      "@react-native-firebase/storage",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "EXPO_PUBLIC_API_URL": "https://api.hairconnekt.de",
      "eas": {
        "projectId": "14bc003c-cd0f-4834-90e2-b4f6c64bdf7e"
      }
    }
  }
}
NODE_ENV=production
PORT=3000
APP_URL=https://api.hairconnekt.de
FRONTEND_URL=https://hairconnekt.de

DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
DATABASE_SSL=true

JWT_ACCESS_SECRET=change_me_access_secret_min_16_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret_min_16_chars
JWT_REFRESH_EXPIRES_IN=7d

# Backblaze B2
B2_S3_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
B2_S3_REGION=eu-central-003
B2_BUCKET=hairconnekt-images
B2_PUBLIC_URL=https://f003.backblazeb2.com/file

# SMTP (Brevo)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-username-or-api
SMTP_PASS=your-brevo-password-or-key
SMTP_SECURE=false
SMTP_FROM=noreply@hairconnekt.de

GOOGLE_MAPS_API_KEY=your-google-maps-key
